# BeliefOS environment configuration
# Copy to .env and edit. Loaded automatically by pydantic-settings.

# Runtime
BELIEFOS_ENV=development
BELIEFOS_HOST=0.0.0.0
BELIEFOS_PORT=8000
BELIEFOS_LOG_LEVEL=info
BELIEFOS_DEBUG=false

# Database (PostgreSQL via asyncpg)
BELIEFOS_DATABASE_URL=postgresql+asyncpg://beliefos:beliefos@localhost:5432/beliefos

# Redis cache + pub/sub
BELIEFOS_REDIS_URL=redis://localhost:6379/0

# CORS (comma-separated origins, or "*" for any)
BELIEFOS_CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Belief dynamics
BELIEFOS_DEFAULT_EMA_WEIGHT=0.30
BELIEFOS_DECAY_HALF_LIFE_SECONDS=3600
BELIEFOS_MIN_CONFIDENCE_OBSERVATIONS=3
BELIEFOS_MIN_CONFIDENCE_TO_ACT=0.40

# Decision thresholds (absolute strength in [0, 1]; 0.5 is neutral)
BELIEFOS_WATCH_THRESHOLD=0.45
BELIEFOS_ALERT_THRESHOLD=0.65
BELIEFOS_CRITICAL_THRESHOLD=0.82
BELIEFOS_ALERT_CONFIDENCE=0.50

# Optional LLM integrations
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional ROS2 bridge (when running inside a robot host)
ROS2_BRIDGE_HOST=127.0.0.1
ROS2_BRIDGE_PORT=8765
